# VerifyEd v2.0 Enterprise Environment Variables Template (.env.example)
# Copy this file to .env or .env.local and fill in your actual values.

# Node Environment
NODE_ENV=development
PORT=4000

# Next.js Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Primary PostgreSQL Database Connection String
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/verifyed_db?schema=public"

# Redis Connection
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Firebase Authentication Credentials (Loaded via process.env)
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"

# Firebase Admin SDK (Backend)
FIREBASE_CLIENT_EMAIL="YOUR_FIREBASE_CLIENT_EMAIL"
FIREBASE_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"

# Polygon & EVM Blockchain Config
POLYGON_AMOY_RPC_URL="https://rpc-amoy.polygon.technology/"
POLYGON_MAINNET_RPC_URL="https://polygon-rpc.com"
ETHERSCAN_POLYGON_API_KEY="YOUR_POLYGONSCAN_API_KEY"
DEPLOYER_PRIVATE_KEY="YOUR_DEPLOYER_PRIVATE_KEY"

# Deployed Smart Contract Addresses
NEXT_PUBLIC_UNIVERSITY_REGISTRY_ADDRESS="YOUR_UNIVERSITY_REGISTRY_CONTRACT_ADDRESS"
NEXT_PUBLIC_CERTIFICATE_REGISTRY_ADDRESS="YOUR_CERTIFICATE_REGISTRY_CONTRACT_ADDRESS"
NEXT_PUBLIC_CERTIFICATE_REVOCATION_ADDRESS="YOUR_CERTIFICATE_REVOCATION_CONTRACT_ADDRESS"

# Pinata IPFS
PINATA_API_KEY="YOUR_PINATA_API_KEY"
PINATA_SECRET_API_KEY="YOUR_PINATA_SECRET_KEY"
PINATA_JWT="YOUR_PINATA_JWT"
NEXT_PUBLIC_IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs/"

# JWT Secrets
JWT_SECRET="YOUR_JWT_SECRET_KEY"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_SECRET="YOUR_REFRESH_TOKEN_SECRET"
REFRESH_TOKEN_EXPIRATION="7d"
